THEME=https://raw.githubusercontent.com/tazpellegrini/abyssalobsidian/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgShowBacklinks=true
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true
SITE_NAME_HEADER=Digital Garden
SITE_MAIN_LANGUAGE=en
